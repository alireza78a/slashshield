{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/claim",
      "destination": "/"
    },
    {
      "source": "/claim/(.*)",
      "destination": "/"
    },
    {
      "source": "/evidence",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/evidence/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
